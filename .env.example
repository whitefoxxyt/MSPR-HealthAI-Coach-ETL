# Connexion à MSPR-DB (réseau Docker externe mspr_data_network)
# DB_HOST pointe vers le container name de MSPR-DB
DB_HOST=mspr-healthai-db
DB_PORT=5432
DB_NAME=healthai
DB_USER=healthai_user
DB_PASSWORD=change_me_with_a_strong_password

# ETL
CRON_SCHEDULE=0 2 * * *
DATA_DIR=/app/data/raw
PROCESSED_DIR=/app/data/processed
SAMPLES_DIR=/app/data/samples
